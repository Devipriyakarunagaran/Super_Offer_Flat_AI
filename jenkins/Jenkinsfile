pipeline {

    agent any

    environment {
        DOCKERHUB_USERNAME = "devipriyadp1"
        BACKEND_IMAGE = "aldi-lidl-backend"
        FRONTEND_IMAGE = "aldi-lidl-frontend"
    }

    stages {

        // ---------------- CLONE CODE ----------------
        stage('Clone Repository') {
            steps {
                git branch: 'main',
                url: 'https://github.com/Devipriyakarunagaran/Super_Offer_Flat_AI.git'
            }
        }

        // ---------------- GET COMMIT ID ----------------
        stage('Get Commit ID') {
            steps {
                script {
                    env.GIT_COMMIT_SHORT = sh(
                        script: "git rev-parse --short HEAD",
                        returnStdout: true
                    ).trim()
                }
            }
        }

        // ---------------- BUILD BACKEND ----------------
        stage('Build Backend Image') {
            steps {
                sh '''
                docker build -t $DOCKERHUB_USERNAME/$BACKEND_IMAGE:$GIT_COMMIT_SHORT ./backend
                '''
            }
        }

        // ---------------- BUILD FRONTEND ----------------
        stage('Build Frontend Image') {
            steps {
                sh '''
                docker build -t $DOCKERHUB_USERNAME/$FRONTEND_IMAGE:$GIT_COMMIT_SHORT ./frontend
                '''
            }
        }

        // ---------------- DOCKER LOGIN ----------------
        stage('DockerHub Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    '''
                }
            }
        }

        // ---------------- PUSH BACKEND ----------------
        stage('Push Backend Image') {
            steps {
                sh '''
                docker push $DOCKERHUB_USERNAME/$BACKEND_IMAGE:$GIT_COMMIT_SHORT
                '''
            }
        }

        // ---------------- PUSH FRONTEND ----------------
        stage('Push Frontend Image') {
            steps {
                sh '''
                docker push $DOCKERHUB_USERNAME/$FRONTEND_IMAGE:$GIT_COMMIT_SHORT
                '''
            }
        }

        // ---------------- RUN SCRAPER (DATA INGESTION) ----------------
        stage('Run Scraper') {
            steps {
                sh '''
                echo "Running Aldi + Lidl scraper..."
                python3 backend/scraper/run_scraper.py
                '''
            }
        }

        // ---------------- UPDATE HELM VALUES (GITOPS) ----------------
        stage('Update Helm Values (GitOps)') {
            steps {
                sh '''
                sed -i "s|aldi-lidl-backend:.*|aldi-lidl-backend:$GIT_COMMIT_SHORT|g" aldi-lidl/values.yaml
                sed -i "s|aldi-lidl-frontend:.*|aldi-lidl-frontend:$GIT_COMMIT_SHORT|g" aldi-lidl/values.yaml
                '''
            }
        }

        // ---------------- PUSH HELM CHANGES ----------------
        stage('Commit GitOps Changes') {
            steps {
                sh '''
                git config user.email "jenkins@ci.com"
                git config user.name "jenkins"

                git add .
                git commit -m "auto update images + scraper run: $GIT_COMMIT_SHORT" || true
                git push
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline completed successfully - GitOps updated"
        }

        failure {
            echo "❌ Pipeline failed - check logs"
        }
    }
}
